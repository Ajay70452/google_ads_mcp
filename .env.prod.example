# ─────────────────────────────────────────────────────────────────────────────
# Production env file template.
#
# Copy this to `.env.prod` on the deployment server and fill in real values.
# `.env.prod` is gitignored — never commit real secrets.
#
#   cp .env.prod.example .env.prod
#   chmod 600 .env.prod
#   nano .env.prod
# ─────────────────────────────────────────────────────────────────────────────

# ── Google Ads ────────────────────────────────────────────────────────────────
DEVELOPER_TOKEN=
CLIENT_ID=
CLIENT_SECRET=
REFRESH_TOKEN=
MCC_CUSTOMER_ID=7701109307

# ── Database (internal docker network) ────────────────────────────────────────
# Hostname `postgres` is the docker-compose service name.
DATABASE_URL=postgresql+asyncpg://ga_user:CHANGE_ME_STRONG_PASSWORD@postgres:5432/ga_auto
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Redis (internal docker network) ───────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Backend URL (used by the scheduler container to call the backend) ─────────
BACKEND_URL=http://backend:8001

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Zoho Cliq ─────────────────────────────────────────────────────────────────
CLIQ_ZAPIKEY=
CLIQ_COMPANY_ID=746931876
